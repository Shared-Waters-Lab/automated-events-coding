flowchart TD
    PR[/"PR Data (text)"/]
    M0{{"0 · Relevance Check (BERT classifier)\nOutput: Y/N + metadata"}}

    PR --> E1
    M0 --> E1

    E1["1 · Event Extraction (LLM)\nOutput: list of Events"]
    E1 -->|"Events"| FE1{{"for each Event"}}

    FE1 --> L2["2 · Location Extraction (LLM)\nOutput: Place names"]

    L2 -->|"place names"| CB["2.1 · Country / Basin Lookup\n(rule-based)"]
    L2 -->|"if GW (groundwater)\nmentioned = Y"| AQ["2.2 · Aquifer Lookup\n(rule-based)"]

    CB --> EL3
    AQ --> EL3

    EL3["3 · Event-lead Extraction (LLM)\nOutput: multiday?, day/month/year,\nissue area & scale of impact,\ngroundwater infrastructure"]

    FE1 --> IA4["4 · (Inter)action Extraction (LLM)\nOutput: interactions (pairs),\nactors (a/b), summary, type"]

    IA4 -->|"Events"| FE2{{"for each actor/interaction"}}

    FE2 -->|"if type = action"| A5["5.1 · Action ID (LLM)\nOutput: entity name, entity code"]
    FE2 -->|"else (interaction)"| I5["5.2 · Interaction ID (LLM)\nOutput: entity names, entity codes,\ndyad pairs (2), DYAD code per entity,\nBAR scale"]

    EL3 --> D6
    A5 --> D6
    I5 --> D6

    D6["6 · Event Deduplication (rule-based)\nLook up similar collected events/facts"]

    D6 --> P1["6.1 · Primary match keys:\nDate · Entity list · BCODE"]
    D6 --> P2["6.2 · Secondary match keys:\nDyad pairs · Issue area · BAR scale"]

    P1 --> CHK{"Duplicate found?"}
    P2 --> CHK

    CHK -->|"yes / ambiguous"| HUM["Flag for human review"]
    CHK -->|"no"| STORE[("Store as new event/fact")]

    classDef llm fill:#ffe0e0,stroke:#c62828,stroke-width:1.5px;
    classDef leadllm fill:#fff9c4,stroke:#f9a825,stroke-width:1.5px;
    classDef intllm fill:#c8e6c9,stroke:#2e7d32,stroke-width:1.5px;
    classDef idllm fill:#ffe0b2,stroke:#ef6c00,stroke-width:1.5px;
    classDef classifier fill:#d1c4e9,stroke:#4527a0,stroke-width:1.5px;
    classDef match fill:#e1bee7,stroke:#6a1b9a,stroke-width:1.5px;
    classDef lookup fill:#bbdefb,stroke:#1565c0,stroke-width:1.5px;
    classDef data fill:#f5f5f5,stroke:#616161,stroke-width:1.5px;
    classDef decision fill:#ffffff,stroke:#424242,stroke-width:1.5px;

    class M0 classifier;
    class E1 llm;
    class L2 llm;
    class EL3 leadllm;
    class IA4 intllm;
    class A5,I5 idllm;
    class D6 match;
    class CB,AQ lookup;
    class PR,STORE data;
    class FE1,FE2,CHK decision;
